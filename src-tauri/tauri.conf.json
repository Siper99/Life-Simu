{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "life-sim",
  "version": "0.1.0",
  "identifier": "com.siper99.lifesim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "人生模拟器",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0NkYzMEUwMTZFMEM4RUIKUldUcnlPQVc0REJ2RktZNlhkOW8zdmpOVFZwN2g5QU9xQWJXSWNROTlWOWRQWGczYkxkM3NRWVUK",
      "endpoints": [
        "https://github.com/Siper99/Life-Simu/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
